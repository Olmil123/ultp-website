# Django
SECRET_KEY=django-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# CORS
# For local frontend dev (Vite default port 9999)
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://127.0.0.1:9999,http://localhost:9999
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:9999,http://localhost:9999

# Security flags (set True behind HTTPS in production)
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# API throttling
DRF_THROTTLE_ANON=300/day
DRF_THROTTLE_QUESTIONS_BURST=3/minute
DRF_THROTTLE_QUESTIONS_HOUR=20/hour
DRF_THROTTLE_QUESTIONS_DAY=40/day

# Email (questions notification)
# Dev default (logs emails in Django console):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP example (switch EMAIL_BACKEND when ready):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=no-reply@example.com

# Where question notifications should be sent
QUESTION_NOTIFY_EMAIL=
QUESTION_TIMEZONE=Europe/Kyiv
QUESTION_IP_COOLDOWN_SECONDS=30
QUESTION_EMAIL_COOLDOWN_SECONDS=60
QUESTION_DUPLICATE_TTL_SECONDS=21600
