# Django
SECRET_KEY=django-insecure-change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# CORS
# For local frontend dev (Vite default port 9999)
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://127.0.0.1:9999,http://localhost:9999

# Email (questions notification)
# Dev default (logs emails in Django console):
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP example (switch EMAIL_BACKEND when ready):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=no-reply@example.com

# Where question notifications should be sent
QUESTION_NOTIFY_EMAIL=
